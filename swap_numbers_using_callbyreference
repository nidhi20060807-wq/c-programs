#include<stdio.h>

void swap_num(int *a, int *b){
    int temp = *a;
    *a = *b;
    *b = temp;
}

int main(){
    int x, y;

    printf("Enter x value: ");
    scanf("%d", &x);

    printf("Enter y value: ");
    scanf("%d", &y);

    printf("Before swap: x = %d y = %d\n", x, y);

    swap_num(&x, &y);

    printf("After swap: x = %d y = %d\n", x, y);

    return 0;
}
