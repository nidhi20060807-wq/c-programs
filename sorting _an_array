#include<stdio.h>

int main(){

    int arr[10], temp;

    for(int i=0;i<10;i++){
        printf("Enter element: ");
        scanf("%d",&arr[i]);
    }

    for(int i=0;i<9;i++){
        for(int j=i+1;j<10;j++){
            if(arr[i] > arr[j]){
                temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
            }
        }
    }

    printf("Sorted array:\n");

    for(int i=0;i<10;i++){
        printf("%d ",arr[i]);
    }

    return 0;
}
