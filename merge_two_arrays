#include<stdio.h>

int main(){

    int size1,size2;

    printf("Enter size of first array: ");
    scanf("%d",&size1);

    printf("Enter size of second array: ");
    scanf("%d",&size2);

    int arr1[size1];
    int arr2[size2];

    // input first array
    for(int i=0;i<size1;i++){
        printf("Enter element %d: ",i+1);
        scanf("%d",&arr1[i]);
    }

    // input second array
    for(int i=0;i<size2;i++){
        printf("Enter element %d: ",i+1);
        scanf("%d",&arr2[i]);
    }

    int size3=size1+size2;
    int arr3[size3];

    // copy first array
    for(int i=0;i<size1;i++){
        arr3[i]=arr1[i];
    }

    // copy second array
    for(int i=0;i<size2;i++){
        arr3[size1+i]=arr2[i];
    }

    printf("Merged array:\n");

    for(int i=0;i<size3;i++){
        printf("%d ",arr3[i]);
    }

    return 0;
}
