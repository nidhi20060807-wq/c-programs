#include<stdio.h>

int main(){

int arr[]={1,0,4,0,6};
int size = sizeof(arr)/sizeof(arr[0]);

for(int i=0;i<size;i++){
    if(arr[i]==0){
        for(int j=i;j<size-1;j++){
            arr[j]=arr[j+1];
        }
        arr[size-1]=0;
    }
}

for(int i=0;i<size;i++){
    printf("%d ",arr[i]);
}

return 0;
}
